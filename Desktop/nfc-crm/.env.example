# SUPABASE CONFIGURATION (Zorunlu)
# Vercel Dashboard > Project Settings > Environment Variables içine ekle
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Sadece /api/webhook/shopier serverless function tarafından kullanılır.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# SHOPIER OTOMATİK SİPARİŞ BİLDİRİMİ (OSB)
# Shopier panel > Ayarlar > Entegrasyonlar > Otomatik Sipariş Bildirimi sayfasından alınır.
SHOPIER_OSB_USERNAME="osb-kullanici-adiniz"
SHOPIER_OSB_PASSWORD="osb-sifreniz"
